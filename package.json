{
  "name": "sql2js",
  "version": "1.0.0",
  "description": "SQL-to-JavaScript compiler for JSON data with interactive TUI",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "generate": "antlr4 -Dlanguage=JavaScript -visitor -no-listener grammar/JsonQuery.g4 -o src/generated",
    "start": "node src/index.js",
    "tui": "node src/tui/app.js"
  },
  "dependencies": {
    "antlr4": "^4.13.1",
    "ink": "^4.4.1",
    "ink-text-input": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.2.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11"
  },
  "devDependencies": {}
}
